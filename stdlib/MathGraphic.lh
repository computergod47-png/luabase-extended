/*
- bool intersectRayMesh(rayf ray, meshf mesh, ptr float t)
- mat4f affineInverse(mat4f m)
- mat4f orthonormalInverse(mat4f m)
- mat4f compose(vec3f translation, quatf rotation, vec3f scale)
- void decompose(mat4f m, ptr vec3f translation, ptr quatf rotation, ptr vec3f scale)
- mat4f fromTRS(vec3f translation, quatf rotation, vec3f scale)
- void toTRS(mat4f m, ptr vec3f translation, ptr quatf rotation, ptr vec3f scale)
- mat4f fromSRT(vec3f scale, quatf rotation, vec3f translation)
- void toSRT(mat4f m, ptr vec3f scale, ptr quatf rotation, ptr vec3f translation)
- mat4f fromRS(quatf rotation, vec3f scale)
- void toRS(mat4f m, ptr quatf rotation, ptr vec3f scale)
- mat4f fromSR(vec3f scale, quatf rotation)
*/
// we already have intersectRayMesh, let's implement the rest!
function mat4f affineInverse(mat4f m) {
    mat4f inv
    inv.x = v4(m.x.x, m.y.x, m.z.x, 0.0)
    inv.y = v4(m.x.y, m.y.y, m.z.y, 0.0)
    inv.z = v4(m.x.z, m.y.z, m.z.z, 0.0)
    inv.w = v4(-vec3Dot(v3(m.x.x, m.y.x, m.z.x), v3(m.w.x, m.w.y, m.w.z)),-vec3Dot(v3(m.x.y, m.y.y, m.z.y), v3(m.w.x, m.w.y, m.w.z)),-vec3Dot(v3(m.x.z, m.y.z, m.z.z), v3(m.w.x, m.w.y, m.w.z)),1.0)
    return inv
}
function mat4f orthonormalInverse(mat4f m) {
    mat4f inv
    inv.x = v4(m.x.x, m.y.x, m.z.x, 0.0)
    inv.y = v4(m.x.y, m.y.y, m.z.y, 0.0)
    inv.z = v4(m.x.z, m.y.z, m.z.z, 0.0)
    inv.w = v4(-vec3Dot(v3(m.x.x, m.y.x, m.z.x), v3(m.w.x, m.w.y, m.w.z)),-vec3Dot(v3(m.x.y, m.y.y, m.z.y), v3(m.w.x, m.w.y, m.w.z)),-vec3Dot(v3(m.x.z, m.y.z, m.z.z), v3(m.w.x, m.w.y, m.w.z)),1.0)
    return inv
}
function mat4f compose(vec3f translation, quatf rotation, vec3f scale) {
    mat4f m
    mat4f rot = fromQuat(rotation)
    m.x = v4(rot.x.x * scale.x, rot.y.x * scale.y, rot.z.x * scale.z, 0.0)
    m.y = v4(rot.x.y * scale.x, rot.y.y * scale.y, rot.z.y * scale.z, 0.0)
    m.z = v4(rot.x.z * scale.x, rot.y.z * scale.y, rot.z.z * scale.z, 0.0)
    m.w = v4(translation.x, translation.y, translation.z, 1.0)
    return m
}
function void decompose(mat4f m, ptr vec3f translation, ptr quatf rotation, ptr vec3f scale) {
    scale.x = vec3Length(v3(m.x.x, m.y.x, m.z.x))
    scale.y = vec3Length(v3(m.x.y, m.y.y, m.z.y))
    scale.z = vec3Length(v3(m.x.z, m.y.z, m.z.z))
    if (scale.x > 0.0) then
        m.x.x /= scale.x
        m.y.x /= scale.x
        m.z.x /= scale.x
    end
    if (scale.y > 0.0) then
        m.x.y /= scale.y
        m.y.y /= scale.y
        m.z.y /= scale.y
    end
    if (scale.z > 0.0) then
        m.x.z /= scale.z
        m.y.z /= scale.z
        m.z.z /= scale.z
    end
    *rotation = fromMat4(m)
    translation.x = m.w.x
    translation.y = m.w.y
    translation.z = m.w.z
}
function mat4f fromTRS(vec3f translation, quatf rotation, vec3f scale) {
    return compose(translation, rotation, scale)
}
function void toTRS(mat4f m, ptr vec3f translation, ptr quatf rotation, ptr vec3f scale) {
    decompose(m, translation, rotation, scale)
}
function mat4f fromSRT(vec3f scale, quatf rotation, vec3f translation) {
    return compose(translation, rotation, scale)
}
function void toSRT(mat4f m, ptr vec3f scale, ptr quatf rotation, ptr vec3f translation) {
    decompose(m, translation, rotation, scale)
}
function mat4f fromRS(quatf rotation, vec3f scale) {
    return compose(v3(0.0, 0.0, 0.0), rotation, scale)
}
function void toRS(mat4f m, ptr quatf rotation, ptr vec3f scale) {
    vec3f x = v3(0.0, 0.0, 0.0)
    decompose(m, &x, rotation, scale)
}
function mat4f fromSR(vec3f scale, quatf rotation) {
    return compose(v3(0.0, 0.0, 0.0), rotation, scale)
}
function void toSR(mat4f m, ptr vec3f scale, ptr quatf rotation) {
    vec3f x = v3(0.0, 0.0, 0.0)
    decompose(m, &x, rotation, scale)
}