# Structs and Member Access
type Player {
    int id
    float health
    str name
}

function void show_stats(Player p) {
    print("Player: ", p.name, " [ID: ", p.id, "]\n")
    print("Health: ", p.health, "\n")
}

function void main() {
    Player p1
    p1.id = 1
    p1.health = 100.0
    p1.name = "Mebecool"

    show_stats(p1)
}

main()
